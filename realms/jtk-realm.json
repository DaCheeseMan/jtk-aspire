{
  "realm": "jtk",
  "displayName": "Jonsereds TK",
  "enabled": true,
  "registrationAllowed": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "roles": {
    "realm": [
      {
        "name": "member",
        "description": "Club member"
      },
      {
        "name": "admin",
        "description": "Club administrator"
      }
    ]
  },
  "defaultRoles": [
    "member"
  ],
  "clients": [
    {
      "clientId": "jtk-web",
      "name": "Jonsereds TK Web",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "redirectUris": [
        "https://localhost:5173",
        "https://localhost:5173/*",
        "https://localhost:5174",
        "https://localhost:5174/*",
        "https://*"
      ],
      "webOrigins": [
        "*"
      ],
      "protocol": "openid-connect",
      "protocolMappers": [
        {
          "name": "jtk-web-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "jtk-web",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        },
        {
          "name": "phone-number",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "user.attribute": "phone_number",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "phone_number",
            "jsonType.label": "String"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "member1",
      "email": "member1@jonsereds-tk.se",
      "firstName": "Anna",
      "lastName": "Johansson",
      "enabled": true,
      "credentials": [
        {
          "type": "password",
          "value": "Password1!",
          "temporary": false
        }
      ],
      "realmRoles": [
        "member"
      ],
      "attributes": {
        "phone_number": [
          "073-123 45 67"
        ]
      }
    },
    {
      "username": "admin1",
      "email": "admin1@jonsereds-tk.se",
      "firstName": "Erik",
      "lastName": "Lindberg",
      "enabled": true,
      "credentials": [
        {
          "type": "password",
          "value": "Password1!",
          "temporary": false
        }
      ],
      "realmRoles": [
        "member",
        "admin"
      ],
      "attributes": {
        "phone_number": [
          "070-987 65 43"
        ]
      }
    }
  ]
}
